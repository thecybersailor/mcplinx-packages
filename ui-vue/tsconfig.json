{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "skipLibCheck": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "paths": {
      "@/*": ["./src/*"],
      "vue": ["../../frontend/portal/node_modules/vue"],
      "reka-ui": ["../../frontend/portal/node_modules/reka-ui"],
      "@vueuse/core": ["../../frontend/portal/node_modules/@vueuse/core"],
      "clsx": ["../../frontend/portal/node_modules/clsx"],
      "tailwind-merge": ["../../frontend/portal/node_modules/tailwind-merge"],
      "class-variance-authority": ["../../frontend/portal/node_modules/class-variance-authority"],
      "lucide-vue-next": ["../../frontend/portal/node_modules/lucide-vue-next"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/**"]
}
