{
    "name": "@mcplinx/linktool",
    "version": "0.1.0",
    "description": "DevKit for MCPLINX Connectors",
    "type": "module",
    "bin": {
        "linktool": "./bin/linktool.cjs"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./lib": {
            "import": "./dist/lib/index.js",
            "types": "./dist/lib/index.d.ts"
        },
        "./lib/test-utils": {
            "import": "./dist/lib/test-utils.js",
            "types": "./dist/lib/test-utils.d.ts"
        }
    },
    "scripts": {
        "prebuild": "npm --prefix ../connector-core run build",
        "build": "node scripts/build.js && tsc",
        "watch": "tsc -w",
        "dev": "tsx src/index.ts",
        "linktool": "tsx src/index.ts",
        "test:e2e:pty": "vitest run e2e/pty",
        "test": "vitest",
        "type-check": "tsc --noEmit",
        "prepublishOnly": "npm run build"
    },
    "publishConfig": {
        "access": "public"
    },
    "devDependencies": {
        "@mcplinx/connector-core": "*",
        "@mcplinx/api-client-auth": "*",
        "@mcplinx/api-client-developer": "*",
        "@types/inquirer": "^9.0.7",
        "@types/json5": "^2.2.0",
        "@types/node": "^20.19.27",
        "@types/ws": "^8.5.10",
        "@vitest/ui": "^3.0.8",
        "axios": "^1.6.0",
        "chalk": "^5.3.0",
        "commander": "^12.0.0",
        "dotenv": "^16.4.1",
        "esbuild": "^0.27.2",
        "inquirer": "^9.2.14",
        "json5": "^2.2.3",
        "tsx": "^4.21.0",
        "typescript": "^5.3.3",
        "vitest": "^3.0.8",
        "ws": "^8.16.0",
        "yaml": "^2.4.0"
    },
    "dependencies": {
        "open": "^11.0.0"
    }
}
