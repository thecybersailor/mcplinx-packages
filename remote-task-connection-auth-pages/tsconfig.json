{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "skipLibCheck": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["vitest/globals"]
  },
  "include": [
    "src/index.ts",
    "src/routes.ts",
    "src/facade.ts",
    "src/navigation.ts",
    "src/pages/**/*.vue"
  ],
  "exclude": ["src/**/__tests__/**"]
}
